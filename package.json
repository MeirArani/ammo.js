{
  "name": "@hubs/ammo.js",
  "version": "0.0.3",
  "description": "Direct port of the Bullet physics engine to JavaScript using Emscripten",
  "main": "./dist/ammo.jms",
  "module": "./dist/ammo.mjs",
  "exports": {
    ".": {
      "types": "./dist/ammo.d.ts",
      "import": "./dist/ammo.mjs",
      "require": "./dist/ammo.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/MeirArani/ammo.js.git"
  },
  "author": "Alon Zakai <alonzakai@gmail.com>",
  "bugs": {
    "url": "https://github.com/kripken/ammo.js/issues"
  },
  "homepage": "https://github.com/kripken/ammo.js",
  "devDependencies": {
    "ava": "^3.11.0",
    "typescript": "^6.0.2",
    "unwasm": "^0.5.3",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "webidl-dts-gen": "^1.12.0",
    "webidl2ts": "^1.0.4"
  },
  "scripts": {
    "test": "yarn run test-js && yarn run test-wasm",
    "test-js": "AMMO_PATH=dist/ammo.js ava",
    "test-wasm": "AMMO_PATH=dist/ammo.wasm.js ava",
    "generate": "yarn generate:module && yarn generate:ambient",
    "generate:module": "webidl-dts-gen -i ./ammo.idl -n Ammo -ed -o ./dist/ammo.d.ts",
    "generate:ambient": "webidl-dts-gen -i ./ammo.idl -n Ammo  -e -o ./dist/ammo-ambient.d.ts"
  }
}
